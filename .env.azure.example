# Copy to .env.azure.local and fill in real values.
# Then run:
#   set -a
#   source .env.azure.local
#   set +a
#   ./scripts/azure-provision.sh

AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_RESOURCE_GROUP=gems-marketplace-dev-rg
AZURE_LOCATION=eastus
AZURE_ENVIRONMENT_NAME=dev
AZURE_APP_NAME=gemsmarketplace

POSTGRES_ADMIN_LOGIN=gemsadmin
POSTGRES_ADMIN_PASSWORD=replace-with-a-long-random-password

# Existing separate admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret

# Stripe listing-subscription checkout.
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-signing-secret
STRIPE_CURRENCY=LKR
# Required only when STRIPE_CURRENCY is not LKR.
STRIPE_LKR_PER_UNIT=

# Optional. Defaults to the deployed Azure Web App URL.
PUBLIC_SITE_URL=https://example.com
