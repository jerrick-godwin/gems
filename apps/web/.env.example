# Copy to apps/web/.env for local Vite builds.
# Values here are the public Firebase web app config values, not Firebase Admin service-account JSON.

VITE_API_BASE_URL=http://127.0.0.1:4100

VITE_FIREBASE_API_KEY=replace-with-public-client-api-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=replace-with-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-sender-id
VITE_FIREBASE_APP_ID=replace-with-web-app-id
VITE_FIREBASE_MEASUREMENT_ID=replace-with-measurement-id

VITE_ADMIN_FIREBASE_API_KEY=replace-with-admin-public-client-api-key
VITE_ADMIN_FIREBASE_AUTH_DOMAIN=replace-with-admin-project.firebaseapp.com
VITE_ADMIN_FIREBASE_PROJECT_ID=replace-with-admin-project-id
VITE_ADMIN_FIREBASE_STORAGE_BUCKET=replace-with-admin-project.firebasestorage.app
VITE_ADMIN_FIREBASE_MESSAGING_SENDER_ID=replace-with-admin-sender-id
VITE_ADMIN_FIREBASE_APP_ID=replace-with-admin-web-app-id
VITE_ADMIN_FIREBASE_MEASUREMENT_ID=replace-with-admin-measurement-id

# Backend Stripe settings for local server/webhook testing.
PUBLIC_SITE_URL=http://localhost:4100
STRIPE_PUBLISHABLE_KEY=replace-with-stripe-publishable-key
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-signing-secret
STRIPE_CURRENCY=LKR
# Required only when STRIPE_CURRENCY is not LKR.
STRIPE_LKR_PER_UNIT=
